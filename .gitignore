# Snapshots produced by `pnpm clarity-safety snapshot`. They contain the
# encrypted-secrets master.key and a Postgres / PGlite dump — must never be
# committed. See runbook/README.md "Where to store snapshots safely" (Plan 03).
.planning/snapshots/

# Node
node_modules/
# Exception: the fake-instance test fixture intentionally checks in a
# fake node_modules/ tree so the snapshot filter exclusion test (S2)
# has something to assert on.
!scripts/safety/test/fixtures/fake-instance/**/node_modules/
!scripts/safety/test/fixtures/fake-instance/**/node_modules/**

# Build / IDE / OS
dist/
.DS_Store
Thumbs.db

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# pnpm pack tarballs (transient build artifacts from local pack-and-install spikes)
*.tgz

# Claude Code tool state (harness-managed; not project artifact)
.claude/
