# .npmrc — Plan 02-02 Task 3 SCAF-04 + COEXIST-04 trust-model posture.
# Default-deny postinstall scripts at install time. esbuild's vestigial
# install.js is allowlisted in scripts/audit-postinstall.mjs (NOT here)
# because the platform binary arrives via @esbuild/<platform> optional dep,
# not via the postinstall — so even with ignore-scripts=true the build works.
# See Plan 02-01 SMOKE-FINDINGS §"D-08(f) Postinstall Audit" for the
# empirical evidence (tree diff --ignore-scripts vs default: empty).

# Block ALL lifecycle scripts (postinstall / preinstall / install) at
# `pnpm install` time. Equivalent to passing --ignore-scripts on every
# install command. The audit-postinstall.mjs CI step provides defense in
# depth by failing the build if any unallowlisted dep DECLARES a script
# (even if pnpm wouldn't have run it).
ignore-scripts=true

# Frozen-lockfile posture in CI: pnpm fails if pnpm-lock.yaml drifts from
# package.json. Locally we still allow lockfile updates; CI workflow passes
# --frozen-lockfile explicitly. (This is documentation of the policy here
# rather than a config knob because pnpm v9+ already enforces frozen
# lockfile when CI=true is set.)
